---
interface Props {
  name:         string;
  ageLabel:     string;
  image:        string;
  imageAlt:     string;
  logo:         string;
  ctaLabel:     string;
  ctaHref:      string;
  accentColor?: string;
  ctaVariant?:  'primary' | 'secondary' | 'green';
}

const {
  name,
  ageLabel,
  image,
  imageAlt,
  logo,
  ctaLabel,
  ctaHref,
  accentColor = 'brand-pink',
  ctaVariant = 'primary',
} = Astro.props;

const btnClass = ctaVariant === 'secondary' ? 'btn-secondary' : ctaVariant === 'green' ? 'btn-green' : 'btn-primary';

// Unique SVG path ID per card
const pathId = `age-arc-${name.replace(/[^a-z0-9]/gi, '-').toLowerCase()}`;
---

<article class="flex flex-col items-center text-center bg-white rounded-3xl shadow-md hover:shadow-xl transition-shadow duration-300 p-8 md:p-10">

  <!-- Circular photo -->
  <div class={`w-56 h-56 rounded-full border-4 border-${accentColor} overflow-hidden flex-shrink-0`}>
    <img
      src={image}
      alt={imageAlt}
      class="w-full h-full object-cover"
      loading="lazy"
      width="224"
      height="224"
    />
  </div>

  <!-- Curved age label wrapping around the outside bottom of the circle -->
  <!-- viewBox 224×36: same width as the circle, 36px tall for the curved text -->
  <!-- -mt-3 pulls it up to hug the circle edge; mb-4 gives space before the logo -->
  <svg
    class={`w-56 flex-shrink-0 -mt-3 mb-4 pointer-events-none fill-${accentColor}`}
    viewBox="0 0 224 36"
    aria-hidden="true"
  >
    <defs>
      <!-- Gentle upward arc (r=400) so text smiles below the circle -->
      <path id={pathId} d="M 5,32 A 400,400 0 0,1 219,32" />
    </defs>
    <text
      font-size="16"
      font-weight="600"
      font-family="Fredoka, sans-serif"
      paint-order="stroke"
      stroke="white"
      stroke-width="3"
      stroke-linejoin="round"
    >
      <textPath href={`#${pathId}`} startOffset="50%" text-anchor="middle">
        {ageLabel}
      </textPath>
    </text>
  </svg>

  <!-- Programme logo -->
  <img
    src={logo}
    alt={name}
    class="h-20 w-auto object-contain mb-6"
    loading="lazy"
    width="200"
    height="80"
  />

  <a href={ctaHref} class={`${btnClass} w-full sm:w-auto`}>
    {ctaLabel}
  </a>
</article>
