---

<footer class="bg-gray-900 text-gray-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
    <div class="flex flex-col md:flex-row items-center md:items-start justify-between gap-8">

      <!-- Logo & tagline -->
      <div class="flex flex-col items-center md:items-start gap-3">
        <a href="/" aria-label={siteConfig.name}>
          <img
            src="/images/logo-mutmachmusik.png"
            alt={siteConfig.name}
            class="h-10 w-auto brightness-0 invert"
            width="160"
            height="40"
          />
        </a>
        <p class="text-sm text-gray-400 text-center md:text-left">{siteConfig.tagline}</p>
      </div>

      <!-- Social links -->
      <div class="flex items-center gap-4">
        {siteConfig.social.map(s => (
          <a
            href={s.href}
            aria-label={s.label}
            target="_blank"
            rel="noopener noreferrer"
            class="text-gray-400 hover:text-brand-yellow transition-colors duration-150"
            set:html={socialIcons[s.icon] ?? ''}
          />
        ))}
      </div>
    </div>

    <hr class="border-gray-700 my-8" />

    <!-- Bottom row -->
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-gray-500">
      <p>© {new Date().getFullYear()} {siteConfig.name}. Alle Rechte vorbehalten.</p>
      <nav class="flex gap-6" aria-label="Rechtliche Links">
        <a href="/impressum"   class="hover:text-white transition-colors">Impressum</a>
        <a href="/datenschutz" class="hover:text-white transition-colors">Datenschutz</a>
      </nav>
    </div>
  </div>
</footer>
