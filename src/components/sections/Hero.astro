---
import { siteConfig } from '@/config/site';
import ProgramCard from '@/components/ui/ProgramCard.astro';
const { hero } = siteConfig;
const monkey = siteConfig.programmes[0];
const emma = siteConfig.programmes[1];
---

<section class="relative overflow-hidden bg-white pt-0 pb-20 md:pt-6 md:pb-32">
<div class="relative max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col-reverse md:flex-row items-center gap-2 md:gap-16">

      <!-- Text column -->
      <div class="flex-1 text-center md:text-left -mt-16 md:mt-0">
        <!-- Pill label -->
        <span class="inline-block bg-brand-yellow/30 text-gray-800 font-display font-semibold text-sm px-4 py-1.5 rounded-full mb-6">
          {siteConfig.tagline}
        </span>

        <!-- Programme cards -->
        <div class="mb-6 flex flex-col gap-6">
          <ProgramCard
            name={monkey.name}
            ageLabel={monkey.ageLabel}
            image={monkey.image}
            imageAlt={monkey.imageAlt}
            logo={monkey.logo}
            ctaLabel={monkey.ctaLabel}
            ctaHref={monkey.ctaHref}
            accentColor={monkey.accentColor}
          />
          <ProgramCard
            name={emma.name}
            ageLabel={emma.ageLabel}
            image={emma.image}
            imageAlt={emma.imageAlt}
            logo={emma.logo}
            ctaLabel={emma.ctaLabel}
            ctaHref={emma.ctaHref}
            accentColor={emma.accentColor}
            ctaVariant="secondary"
          />
        </div>

        <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
          <a href={hero.ctaHref} class="btn-primary text-lg px-10 py-4">
            {hero.ctaLabel}
          </a>
          <a href="#termine" class="btn-secondary text-lg px-10 py-4">
            Termine
          </a>
        </div>
      </div>

      <!-- Logo / graphic column -->
      <div class="w-full md:flex-shrink-0 md:w-auto flex justify-center -mt-6">
        <img
          src="/images/logo-mutmachmusik.png"
          alt="Mutmachmusik"
          class="w-full md:w-80 lg:w-96 h-auto mix-blend-multiply"
          width="384"
          height="384"
          loading="eager"
        />
      </div>

    </div>
  </div>
</section>
