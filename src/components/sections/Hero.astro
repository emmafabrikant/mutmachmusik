---
import { siteConfig } from '@/config/site';
const { hero } = siteConfig;
---

<section class="relative overflow-hidden bg-white pt-0 pb-20 md:pt-20 md:pb-32">
<div class="relative max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col-reverse md:flex-row items-center gap-10 md:gap-16">

      <!-- Text column -->
      <div class="flex-1 text-center md:text-left">
        <!-- Pill label -->
        <span class="inline-block bg-brand-yellow/30 text-gray-800 font-display font-semibold text-sm px-4 py-1.5 rounded-full mb-6">
          {siteConfig.tagline}
        </span>

<p class="text-lg sm:text-xl text-gray-500 leading-relaxed mb-10 max-w-xl mx-auto md:mx-0">
          {hero.subheadline}
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center md:justify-start">
          <a href={hero.ctaHref} class="btn-primary text-lg px-10 py-4">
            {hero.ctaLabel}
          </a>
          <a href="#programme" class="btn-secondary text-lg px-10 py-4">
            Unsere Programme
          </a>
        </div>
      </div>

      <!-- Logo / graphic column -->
      <div class="w-full md:flex-shrink-0 md:w-auto flex justify-center -mt-6">
        <img
          src="/images/logo-mutmachmusik.png"
          alt="Mutmachmusik"
          class="w-full md:w-80 lg:w-96 h-auto mix-blend-multiply"
          width="384"
          height="384"
          loading="eager"
        />
      </div>

    </div>
  </div>
</section>
