---
import { siteConfig } from '@/config/site';
import ProgramCard from '@/components/ui/ProgramCard.astro';
---

<section id="programme" class="py-20 md:py-28 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <div class="grid sm:grid-cols-2 gap-8 max-w-3xl mx-auto">
      {siteConfig.programmes.map(p => (
        <ProgramCard
          name={p.name}
          ageLabel={p.ageLabel}
          description={p.description}
          image={p.image}
          imageAlt={p.imageAlt}
          logo={p.logo}
          ctaLabel={p.ctaLabel}
          ctaHref={p.ctaHref}
          accentColor={p.accentColor}
        />
      ))}
    </div>
  </div>
</section>
