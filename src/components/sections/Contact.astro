---
import { siteConfig } from '@/config/site';
const { contact } = siteConfig;
---

<section id="kontakt" class="py-20 md:py-28 bg-gray-50">
  <div class="max-w-2xl mx-auto px-4 sm:px-6">

    <div class="text-center mb-12">
      <h2 class="section-heading">Kontakt aufnehmen</h2>
      <p class="section-subheading">
        Für Buchungsanfragen, Workshops und Fortbildungen – wir melden uns schnell!
      </p>
    </div>

    <form
      action={`https://formspree.io/f/${contact.formspreeId}`}
      method="POST"
      class="bg-white rounded-3xl shadow-md p-8 md:p-10 space-y-6"
      novalidate
    >
      <!-- Name + Email -->
      <div class="grid sm:grid-cols-2 gap-6">
        <div>
          <label for="contact-name" class="block text-sm font-semibold text-gray-700 mb-2">
            Name <span class="text-brand-pink">*</span>
          </label>
          <input
            type="text"
            id="contact-name"
            name="name"
            required
            autocomplete="name"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-brand-pink focus:ring-2 focus:ring-brand-pink/20 outline-none transition"
          />
        </div>
        <div>
          <label for="contact-email" class="block text-sm font-semibold text-gray-700 mb-2">
            E-Mail <span class="text-brand-pink">*</span>
          </label>
          <input
            type="email"
            id="contact-email"
            name="email"
            required
            autocomplete="email"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-brand-pink focus:ring-2 focus:ring-brand-pink/20 outline-none transition"
          />
        </div>
      </div>

      <!-- Subject dropdown -->
      <div>
        <label for="contact-subject" class="block text-sm font-semibold text-gray-700 mb-2">
          Betreff
        </label>
        <select
          id="contact-subject"
          name="subject"
          class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-brand-pink focus:ring-2 focus:ring-brand-pink/20 outline-none transition bg-white"
        >
          <option value="">Bitte auswählen…</option>
          <option value="Konzert buchen">Konzert buchen</option>
          <option value="Workshop anfragen">Workshop anfragen</option>
          <option value="Fortbildung anfragen">Fortbildung anfragen</option>
          <option value="Sonstiges">Sonstiges</option>
        </select>
      </div>

      <!-- Message -->
      <div>
        <label for="contact-message" class="block text-sm font-semibold text-gray-700 mb-2">
          Nachricht <span class="text-brand-pink">*</span>
        </label>
        <textarea
          id="contact-message"
          name="message"
          required
          rows="5"
          class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-brand-pink focus:ring-2 focus:ring-brand-pink/20 outline-none transition resize-none"
        ></textarea>
      </div>

      <!-- GDPR notice -->
      <p class="text-xs text-gray-400 leading-relaxed">
        Mit dem Absenden stimmt ihr der Verarbeitung eurer Daten zur Bearbeitung eurer Anfrage zu.
        Weitere Informationen findet ihr in unserer <a href="/datenschutz" class="underline hover:text-brand-pink">Datenschutzerklärung</a>.
      </p>

      <!-- Submit -->
      <div class="text-center pt-2">
        <button type="submit" class="btn-primary text-lg px-12 py-4">
          Nachricht senden
        </button>
      </div>
    </form>
  </div>
</section>
