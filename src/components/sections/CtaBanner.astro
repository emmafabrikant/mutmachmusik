---
import { siteConfig } from '@/config/site';
const { cta } = siteConfig;
---

<section class="py-20 md:py-28 bg-brand-pink relative overflow-hidden">
  <!-- Decorative shapes -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0">
    <div class="absolute -top-16 -right-16 w-64 h-64 rounded-full bg-white/10"></div>
    <div class="absolute -bottom-10 -left-10 w-48 h-48 rounded-full bg-white/10"></div>
    <div class="absolute top-1/2 left-1/3 w-32 h-32 rounded-full bg-brand-yellow/20 -translate-y-1/2"></div>
  </div>

  <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
    <h2 class="font-display text-4xl sm:text-5xl font-bold text-white mb-4 leading-tight">
      {cta.headline}
    </h2>
    <p class="text-lg text-white/80 mb-10">
      {cta.subheadline}
    </p>
    <a
      href={cta.buttonHref}
      class="inline-block bg-white text-brand-pink font-display font-bold text-lg px-10 py-4 rounded-full hover:bg-brand-yellow hover:text-gray-900 transition-colors duration-200 shadow-lg"
    >
      {cta.buttonLabel}
    </a>
  </div>
</section>
